{{!
    @template auth_qrcode/confirmationcode_input_modal

    Template for the confirmation code input modal.

    Example context (json):
    {
    }
}}
{{< core/modal }}
    {{$title}}{{#str}}enterconfirmationcode, auth_qrcode{{/str}}{{/title}}
    {{$body}}
        <div class="container">
            <p>{{#str}}enterconfirmationcodeexplanation, auth_qrcode{{/str}}</p>
            <label for="confirmationcode-input" class="visually-hidden">{{#str}}confirmationcode, auth_qrcode{{/str}}</label>
            <div class="d-flex justify-content-center">
                <input type="text" id="confirmationcode-input" class="form-control w-100" inputmode="numeric" pattern="\d*" autocomplete="off">
            </div>
            <div id="confirmationcode-error" class="text-danger mt-3 hidden" role="alert"></div>
        </div>
    {{/body}}
{{/ core/modal }}