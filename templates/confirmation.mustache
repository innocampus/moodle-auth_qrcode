{{!
    @template auth_qrcode/login
}}
<div class="confirmation-container">
    <!-- Confirmation message -->
    <div class="confirmation-message mt-3 mb-3">{{#str}}confirmation, auth_qrcode{{/str}}</div>
    <ul class="token-info">
        <li>{{#str}}ip, auth_qrcode{{/str}}: {{ip}}</li>
        <li>{{#str}}os, auth_qrcode{{/str}}: {{os}}</li>
        <li>{{#str}}browser, auth_qrcode{{/str}}: {{browser}}</li>
    </ul>
    <!-- Confirmation buttons -->
    <div class="confirmation-buttons text-center">
        <a href="{{yes_url}}" class="btn btn-primary w-50 mb-3">{{#str}}yes, core{{/str}}</a>
        <a href="{{no_url}}" class="btn btn-secondary w-50">{{#str}}no, core{{/str}}</a>
    </div>
</div>
